{
  "_meta": {
    "purpose": "Resolve a shadcncraft Figma icon to the correct export name in the project's configured icon library. shadcncraft kit icons are authored against canonical Lucide names; each canonical name maps to the export name in lucide, tabler, hugeicons, phosphor, and remixicon.",
    "how_to_use": "1. Read iconLibrary from the project's components.json (lucide | tabler | hugeicons | phosphor | remixicon). 2. Take the icon's canonical (Lucide) name from the Figma layer/component name. 3. Look it up in `icons` and read the value for the configured library. 4. Emit the import from that library using the import_paths below. If a name is missing here, fall back to the library's own naming convention (see naming_conventions) and flag it for review rather than guessing silently.",
    "import_paths": {
      "lucide": {
        "package": "lucide-react",
        "example": "import { ArrowRight } from \"lucide-react\";"
      },
      "tabler": {
        "package": "@tabler/icons-react",
        "example": "import { IconArrowRight } from \"@tabler/icons-react\";"
      },
      "hugeicons": {
        "package": "@hugeicons/react + @hugeicons/core-free-icons",
        "example": "import { HugeiconsIcon } from \"@hugeicons/react\"; import { ArrowRight01Icon } from \"@hugeicons/core-free-icons\"; // <HugeiconsIcon icon={ArrowRight01Icon} />"
      },
      "phosphor": {
        "package": "@phosphor-icons/react",
        "example": "import { ArrowRight } from \"@phosphor-icons/react\"; // note: shadcncraft maps record the Icon suffix, e.g. ArrowRightIcon"
      },
      "remixicon": {
        "package": "@remixicon/react",
        "example": "import { RiArrowRightLine } from \"@remixicon/react\";"
      }
    },
    "naming_conventions": {
      "lucide": "PascalCase, optional `Icon` suffix (ArrowRight or ArrowRightIcon).",
      "tabler": "`Icon` prefix + PascalCase (IconArrowRight).",
      "hugeicons": "PascalCase + numbered weight + `Icon` suffix (ArrowRight01Icon). Rendered via <HugeiconsIcon icon={...} />, not as a direct component.",
      "phosphor": "PascalCase + `Icon` suffix (ArrowRightIcon).",
      "remixicon": "`Ri` prefix + PascalCase + style suffix Line/Fill (RiArrowRightLine)."
    },
    "known_traps": {
      "hugeicons_duplicate_names": "Hugeicons' free set contains duplicated/garbled export names (e.g. a 'smilesmile' style doubling). Never infer a hugeicons name by string-doubling or by appending a weight blindly. If a hugeicons value is absent from this map, do not invent one \u2014 surface it for human review and prefer the project's configured library if it is not hugeicons.",
      "semantic_divergence": "Some canonical names map to a semantically different name per library (Bolt -> hugeicons ZapIcon, phosphor LightningIcon). Trust this map over literal name matching.",
      "icon_suffix": "Lucide keys here are inconsistent about the `Icon` suffix because they mirror how the kit authored them (ArrowRight vs ArrowDownIcon). Match the project's existing imports for suffix style; both resolve in lucide-react."
    },
    "seed_source": "Harvested from <IconPlaceholder> usages across src/registry/bases/ (hand-verified 5-library tuples) merged with lucide-icon-crosswalk.json. Regenerate with scripts/build-icon-matrix.py.",
    "count": 107,
    "fully_mapped": 107
  },
