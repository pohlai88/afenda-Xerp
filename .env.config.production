# Production overlay — merged via:
#   pnpm env:sync -- --overlay production
#   pnpm env:sync -- --overlay production --vercel production
#
# Vercel injects VERCEL_GIT_COMMIT_SHA at runtime for worker release alignment.

NEXT_PUBLIC_STAGE=production
OUTBOX_SCHEDULER_REQUIRED=true
WORKER_RELEASE_CHECK_REQUIRED=true
ALLOW_DEGRADED_EXECUTION=false
