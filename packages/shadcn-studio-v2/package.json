{
  "name": "@afenda/shadcn-studio-v2",
  "version": "0.0.0",
  "private": true,
  "description": "Reference-style shadcn/studio presentation package scaffold for taxonomy migration.",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./clients": {
      "types": "./dist/clients.d.ts",
      "import": "./dist/clients.js",
      "default": "./dist/clients.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./metadata": {
      "types": "./dist/metadata.d.ts",
      "import": "./dist/metadata.js",
      "default": "./dist/metadata.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\"",
    "test": "vitest run",
    "test:taxonomy": "vitest run src/__tests__/taxonomy.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@afenda/typescript-config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vitest": "catalog:"
  }
}
