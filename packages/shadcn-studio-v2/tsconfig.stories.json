{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@afenda/shadcn-studio-v2": ["./src/index.ts"],
      "@/*": ["./src/*"],
      "storybook/test": [
        "../../apps/storybook/node_modules/storybook/dist/test/index.d.ts"
      ]
    }
  },
  "include": [
    "src/index.ts",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/storybook/**/*.ts",
    "src/storybook/**/*.tsx"
  ],
  "exclude": ["dist", "node_modules", "src/**/__tests__/**"]
}
