{
  "name": "@afenda/metadata-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Governed metadata rendering for Afenda ERP surfaces",
  "type": "module",
  "sideEffects": [
    "./dist/afenda-metadata-ui.css",
    "./dist/fixtures/metadata-ui-fixtures.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./afenda-metadata-ui.css": {
      "types": "./dist/afenda-metadata-ui.css",
      "import": "./dist/afenda-metadata-ui.css",
      "default": "./dist/afenda-metadata-ui.css"
    },
    "./fixtures.css": {
      "types": "./dist/fixtures/metadata-ui-fixtures.css",
      "import": "./dist/fixtures/metadata-ui-fixtures.css",
      "default": "./dist/fixtures/metadata-ui-fixtures.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && node --input-type=module -e \"import { copyFileSync, mkdirSync } from 'node:fs'; mkdirSync('dist/fixtures', { recursive: true }); copyFileSync('src/afenda-metadata-ui.css', 'dist/afenda-metadata-ui.css'); copyFileSync('src/fixtures/metadata-ui-fixtures.css', 'dist/fixtures/metadata-ui-fixtures.css');\"",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.vitest.json --noEmit && tsc -p tsconfig.stories.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@afenda/ui-composition": "workspace:*",
    "@afenda/ui": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@afenda/testing": "workspace:*",
    "@afenda/typescript-config": "workspace:*",
    "@storybook/react": "^10.4.6",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vitest": "catalog:"
  }
}
