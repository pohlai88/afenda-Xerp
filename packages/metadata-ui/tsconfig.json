{
  "extends": "@afenda/typescript-config/strict-react-library.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/_storybook/**",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "references": [{ "path": "../ui-composition" }]
}
