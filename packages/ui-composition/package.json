{
  "name": "@afenda/ui-composition",
  "version": "0.2.0",
  "private": true,
  "description": "Governed UI composition authority contracts for Afenda (surfaces, layouts, sections, renderers)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\""
  },
  "sideEffects": false,
  "dependencies": {
    "@afenda/accounting-standards": "workspace:*",
    "@afenda/enterprise-knowledge": "workspace:*"
  },
  "devDependencies": {
    "@afenda/typescript-config": "workspace:*",
    "vitest": "catalog:"
  }
}
