{
  "name": "@afenda/auth",
  "version": "0.0.0",
  "private": true,
  "description": "Authentication foundation (Better Auth in TIP-004)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/auth.client.d.ts",
      "import": "./dist/auth.client.js",
      "default": "./dist/auth.client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\""
  },
  "sideEffects": false,
  "peerDependencies": {
    "next": "catalog:",
    "react": "catalog:"
  },
  "devDependencies": {
    "@afenda/typescript-config": "workspace:*",
    "next": "catalog:",
    "react": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@afenda/database": "workspace:^",
    "better-auth": "^1.6.19"
  }
}
