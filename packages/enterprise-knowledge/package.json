{
  "name": "@afenda/enterprise-knowledge",
  "version": "0.0.0",
  "private": true,
  "description": "Enterprise knowledge charter registry — Knowledge Atoms, acceptance, integrity (PAS-004)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\"",
    "check:knowledge-json-authority": "tsx ../../scripts/governance/check-knowledge-json-authority.mts"
  },
  "sideEffects": false,
  "dependencies": {},
  "devDependencies": {
    "@afenda/typescript-config": "workspace:*",
    "vitest": "catalog:"
  }
}
