{
  "extends": "@afenda/typescript-config/strict-react-library.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/components-ui/*": [
        "./src/components-ui/*"
      ],
      "@/components-layouts/*": [
        "./src/components-layouts/*"
      ],
      "@/components-auth-shell/*": [
        "./src/components-auth-shell/*"
      ],
      "@/components-app-shell/*": [
        "./src/components-app-shell/*"
      ],
      "@/components-assets/*": [
        "./src/components-assets/*"
      ],
      "@/lib/*": [
        "./src/lib/*"
      ],
      "@/hooks/*": [
        "./src/hooks/*"
      ],
      "@/utils/utils": [
        "./src/utils/utils.ts"
      ],
      "@/lib/utils": [
        "./src/utils/utils.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "src/storybook/shadcn-studio-theme-lab.compositions.tsx"
  ]
}
