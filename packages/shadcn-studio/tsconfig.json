{
  "extends": "@afenda/typescript-config/strict-react-library.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/.tsbuildinfo",
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/components/ui/*": ["./src/components-ui/*"],
      "@/components/shadcn-studio/*": ["./src/components-layouts/*"],
      "@/components-quarantine/blocks": ["./src/components-quarantine/blocks"],
      "@/components-quarantine/blocks/*": [
        "./src/components-quarantine/blocks/*"
      ],
      "@/components-quarantine/components": [
        "./src/components-quarantine/components"
      ],
      "@/components-quarantine/components/*": [
        "./src/components-quarantine/components/*"
      ],
      "@/components-quarantine/*": ["./src/components-quarantine/*"],
      "@/components-auth-shell/*": ["./src/components-auth-shell/*"],
      "@/components-app-shell/*": ["./src/components-app-shell/*"],
      "@/components-assets/*": ["./src/components-assets/*"],
      "@/lib/utils": ["./src/utils/utils.ts"],
      "@/utils/utils": ["./src/utils/utils.ts"],
      "@/lib/*": ["./src/lib/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "src/storybook/shadcn-studio-theme-lab.compositions.tsx"
  ]
}
