{
  "name": "@afenda/shadcn-studio",
  "version": "0.0.0",
  "private": true,
  "description": "shadcn/studio presentation product — theme surface, presets, MCP install targets (PAS-006A)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./metadata": {
      "types": "./dist/metadata.d.ts",
      "import": "./dist/metadata.js",
      "default": "./dist/metadata.js"
    },
    "./theme": {
      "types": "./dist/theme-runtime/index.d.ts",
      "import": "./dist/theme-runtime/index.js",
      "default": "./dist/theme-runtime/index.js"
    },
    "./governance": {
      "types": "./dist/meta-gates/index.d.ts",
      "import": "./dist/meta-gates/index.js",
      "default": "./dist/meta-gates/index.js"
    },
    "./lab": {
      "types": "./dist/lab.d.ts",
      "import": "./dist/lab.js",
      "default": "./dist/lab.js"
    },
    "./shadcn-default.css": {
      "types": "./dist/shadcn-default.css.d.ts",
      "import": "./dist/shadcn-default.css",
      "default": "./dist/shadcn-default.css"
    },
    "./themes/swiss-noir.css": {
      "types": "./dist/themes/swiss-noir.css.d.ts",
      "import": "./dist/themes/swiss-noir.css",
      "default": "./dist/themes/swiss-noir.css"
    },
    "./themes/verdant-noir.css": {
      "types": "./dist/themes/verdant-noir.css.d.ts",
      "import": "./dist/themes/verdant-noir.css",
      "default": "./dist/themes/verdant-noir.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && tsc-alias -p tsconfig.json && node --input-type=module -e \"import { copyFileSync, mkdirSync } from 'node:fs'; mkdirSync('dist/themes', { recursive: true }); copyFileSync('src/styles/shadcn-default.css', 'dist/shadcn-default.css'); copyFileSync('src/types/css-export.d.ts', 'dist/shadcn-default.css.d.ts'); copyFileSync('src/styles/themes/swiss-noir.css', 'dist/themes/swiss-noir.css'); copyFileSync('src/types/css-export.d.ts', 'dist/themes/swiss-noir.css.d.ts'); copyFileSync('src/styles/themes/verdant-noir.css', 'dist/themes/verdant-noir.css'); copyFileSync('src/types/css-export.d.ts', 'dist/themes/verdant-noir.css.d.ts');\"",
    "build:local": "node ./scripts/build-local.mjs",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.vitest.json --noEmit && tsc -p tsconfig.stories.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\""
  },
  "sideEffects": [
    "./dist/shadcn-default.css",
    "./dist/themes/swiss-noir.css",
    "./dist/themes/verdant-noir.css"
  ],
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@shadcn/react": "^0.1.0",
    "@stepperize/react": "^7.0.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "motion": "12.40.0",
    "next-themes": "^0.4.6",
    "papaparse": "^5.5.4",
    "react-19-credit-card": "^1.0.5",
    "react-day-picker": "^10.0.1",
    "react-payment-inputs": "^1.2.0",
    "react-resizable-panels": "^4.12.0",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "xlsx": "^0.18.5"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@afenda/testing": "workspace:*",
    "@afenda/typescript-config": "workspace:*",
    "@storybook/react": "^10.4.6",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/papaparse": "^5.5.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-payment-inputs": "^1.1.4",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "^4.11.0",
    "tsc-alias": "^1.8.10",
    "tw-animate-css": "1.4.0",
    "vitest": "catalog:"
  }
}
