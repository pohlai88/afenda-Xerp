{
  "name": "@afenda/shadcn-studio",
  "version": "0.0.0",
  "private": true,
  "description": "shadcn/studio presentation product — theme surface, presets, MCP install targets (PAS-005A MVP Authority)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./shadcn-studio.css": {
      "import": "./dist/shadcn-studio.css",
      "default": "./dist/shadcn-studio.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && node --input-type=module -e \"import { copyFileSync } from 'node:fs'; copyFileSync('src/styles/shadcn-studio.css', 'dist/shadcn-studio.css');\"",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\""
  },
  "sideEffects": [
    "./dist/shadcn-studio.css"
  ],
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.525.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "tailwind-merge": "^3.6.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@afenda/testing": "workspace:*",
    "@afenda/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vitest": "catalog:"
  }
}
