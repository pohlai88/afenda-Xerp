{
  "name": "@afenda/shadcn-studio",
  "version": "0.0.0",
  "private": true,
  "description": "shadcn/studio presentation product — theme surface, presets, MCP install targets (PAS-005A MVP Authority)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./shadcn-studio.css": {
      "types": "./dist/shadcn-studio.css.d.ts",
      "import": "./dist/shadcn-studio.css",
      "default": "./dist/shadcn-studio.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && tsc-alias -p tsconfig.json && node --input-type=module -e \"import { copyFileSync } from 'node:fs'; copyFileSync('src/styles/shadcn-studio.css', 'dist/shadcn-studio.css'); copyFileSync('export-stubs/shadcn-studio.css.d.ts', 'dist/shadcn-studio.css.d.ts');\"",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.vitest.json --noEmit && tsc -p tsconfig.stories.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\""
  },
  "sideEffects": [
    "./dist/shadcn-studio.css"
  ],
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.3.0",
    "@shadcn/react": "^0.1.0",
    "@tanstack/react-table": "^8.21.3",
    "@vis.gl/react-google-maps": "^1.8.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "motion": "12.40.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react-19-credit-card": "^1.0.5",
    "react-day-picker": "^10.0.1",
    "react-payment-inputs": "^1.2.0",
    "react-resizable-panels": "^4.12.0",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@afenda/testing": "workspace:*",
    "@afenda/typescript-config": "workspace:*",
    "@storybook/react": "^10.4.6",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/google.maps": "^3.65.2",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-payment-inputs": "^1.1.4",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsc-alias": "^1.8.10",
    "vitest": "catalog:"
  }
}
