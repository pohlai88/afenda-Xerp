{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@afenda/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@afenda/shadcn-studio/lab": ["./src/lab/index.ts"],
      "@afenda/shadcn-studio": ["./src/index.ts"],
      "@/components/ui/*": ["./src/components-ui/*"],
      "@/components/shadcn-studio/*": ["./src/components-layouts/*"],
      "@/components-auth-shell/*": ["./src/components-auth-shell/*"],
      "@/components-app-shell/*": ["./src/components-app-shell/*"],
      "@/components-assets/*": ["./src/components-assets/*"],
      "@/lib/utils": ["./src/utils/utils.ts"],
      "@/lib/*": ["./src/lib/*"],
      "@/hooks/*": ["./src/hooks/*"],
      "@/*": ["./src/*"],
      "storybook/test": [
        "../../apps/storybook/node_modules/storybook/dist/test/index.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/storybook/**/*.ts",
    "src/storybook/**/*.tsx",
    "src/lab/**/*.ts",
    "src/lab/**/*.tsx",
    "src/components-ui/**/*.tsx",
    "src/components-layouts/**/*.tsx",
    "src/components-auth-shell/**/*.tsx",
    "src/components-app-shell/**/*.tsx",
    "src/theme/**/*.tsx",
    "src/theme/**/*.ts",
    "src/hooks/**/*.ts",
    "src/lib/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "src/**/__tests__/**"]
}
