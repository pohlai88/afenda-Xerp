{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@afenda/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@/*": ["./src/*"],
      "@/components/ui/*": ["./src/components/ui/*"],
      "@/components/shadcn-studio/*": ["./src/components/shadcn-studio/*"],
      "@/lib/utils": ["./src/lib/utils.ts"],
      "@/hooks/*": ["./src/hooks/*"]
    }
  },
  "include": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/_storybook/**/*.ts",
    "src/_storybook/**/*.tsx",
    "src/components/**/*.tsx",
    "src/theme/**/*.tsx",
    "src/theme/**/*.ts",
    "src/hooks/**/*.ts",
    "src/lib/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "src/**/__tests__/**"]
}
