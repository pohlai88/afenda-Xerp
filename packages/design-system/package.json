{
  "name": "@afenda/design-system",
  "version": "0.0.0",
  "private": true,
  "description": "Design tokens and UI governance foundation — Afenda-prefixed authority",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./css/afenda-tokens.css": {
      "import": "./dist/css/tokens.css",
      "default": "./dist/css/tokens.css"
    },
    "./css/afenda-design-system.css": {
      "import": "./dist/css/afenda-design-system.css",
      "default": "./dist/css/afenda-design-system.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && tsx scripts/generate-tokens-css.ts",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.vitest.json --noEmit && tsc -p tsconfig.scripts.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "check:governance": "vitest run --config vitest.config.ts src/__tests__/index.test.ts",
    "check:public-api": "tsx src/scripts/check-public-api.ts",
    "check:token-prefix": "tsx src/scripts/check-token-prefix.ts",
    "check:no-runtime-ui": "tsx src/scripts/check-no-runtime-ui.ts",
    "check:no-deep-imports": "tsx src/scripts/check-no-deep-imports.ts",
    "check:no-duplicate-authority": "tsx src/scripts/check-no-duplicate-authority.ts",
    "check:contrast": "tsx src/scripts/check-contrast.ts",
    "check:all": "tsx src/scripts/check-governance.ts",
    "dev": "tsc -b --watch",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\""
  },
  "sideEffects": [
    "./dist/css/tokens.css",
    "./dist/css/afenda-design-system.css"
  ],
  "devDependencies": {
    "@afenda/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsx": "^4.20.3",
    "vitest": "catalog:"
  }
}
