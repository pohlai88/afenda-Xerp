{
  "name": "@afenda/appshell",
  "version": "0.0.0",
  "private": true,
  "description": "ERP application shell foundation",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./afenda-appshell.css": {
      "types": "./dist/styles/afenda-appshell.css",
      "import": "./dist/styles/afenda-appshell.css",
      "default": "./dist/styles/afenda-appshell.css"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.js",
      "default": "./dist/context/index.js"
    }
  },
  "sideEffects": [
    "./dist/styles/afenda-appshell.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && node --input-type=module -e \"import { copyFileSync, mkdirSync } from 'node:fs'; mkdirSync('dist/styles', { recursive: true }); copyFileSync('src/styles/afenda-appshell.css', 'dist/styles/afenda-appshell.css'); copyFileSync('src/styles/afenda-appshell-studio.css', 'dist/styles/afenda-appshell-studio.css');\"",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.vitest.json --noEmit && tsc -p tsconfig.stories.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "test:interaction": "vitest run --config vitest.config.ts .interaction.test",
    "check:governance": "vitest run --config vitest.config.ts src/__tests__/governed-ui-consumption.test.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@afenda/kernel": "workspace:*",
    "@afenda/ui": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "lucide-react": "^0.525.0",
    "react-grid-layout": "^2.2.3",
    "recharts": "3.8.0"
  },
  "peerDependencies": {
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@afenda/testing": "workspace:*",
    "@afenda/typescript-config": "workspace:*",
    "@storybook/react": "^10.4.6",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-grid-layout": "^2.1.0",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "vitest": "catalog:"
  }
}
