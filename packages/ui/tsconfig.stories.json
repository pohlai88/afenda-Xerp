{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@afenda/typescript-config/base.json",
  "compilerOptions": {
    "customConditions": ["@afenda/ui/development", "development"],
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "paths": {
      "@/*": ["./src/*"],
      "#/*": ["./src/*"],
      "@/governance": ["./src/governance/index.ts"],
      "@/governance/*": ["./src/governance/*"],
      "#/governance": ["./src/governance/index.ts"],
      "#/governance/*": ["./src/governance/*"],
      "#/lib/utils": ["./src/lib/utils.ts"],
      "@afenda/ui/governance": ["./src/governance/index.ts"],
      "@afenda/ui/governance/*": ["./src/governance/*"],
      "@afenda/ui/lib/utils": ["./src/lib/utils.ts"],
      "@afenda/ui/lib/*": ["./src/lib/*"],
      "@afenda/ui": ["./src/index.ts"],
      "next/link": ["../testing/src/mocks/next-link.tsx"]
    }
  },
  "include": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/components/**/*.tsx",
    "src/governance/**/*.ts",
    "src/governance/**/*.tsx",
    "src/components/_storybook/**/*.ts",
    "src/components/_storybook/**/*.tsx"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "src/components/shadcn-studio/**"
  ]
}
