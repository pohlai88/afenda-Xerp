{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@afenda/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "rootDir": ".",
    "paths": {
      "@/*": ["./src/*"],
      "#/*": ["./src/*"],
      "@afenda/ui/governance": ["./src/governance/index.ts"],
      "@afenda/ui/governance/component-props": [
        "./src/governance/component-props.ts"
      ],
      "@afenda/ui/governance/primitive-governance": [
        "./src/governance/primitive-governance.ts"
      ],
      "@afenda/ui/governance/governed-render": [
        "./src/governance/governed-render.ts"
      ],
      "@afenda/ui/governance/create-governed-slot": [
        "./src/governance/create-governed-slot.tsx"
      ],
      "@afenda/ui/lib/utils": ["./src/lib/utils.ts"]
    }
  },
  "include": [
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "vitest.storybook.config.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
