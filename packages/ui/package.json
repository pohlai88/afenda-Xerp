{
  "name": "@afenda/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared UI primitives foundation",
  "type": "module",
  "imports": {
    "#/*": {
      "@afenda/ui/development": "./src/*",
      "default": "./dist/*"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./afenda-style.css": "./src/styles/afenda-style.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./governance": "./src/governance/index.ts",
    "./governance/*": "./src/governance/*",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.lib.json",
    "dev": "tsc -b tsconfig.lib.json --watch",
    "typecheck": "tsc -b tsconfig.lib.json --pretty false && tsc -p tsconfig.storybook.json --noEmit && tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "test:ui": "vitest --config vitest.config.ts --ui",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "check:design-system": "tsx scripts/check-design-system-consumption.ts",
    "check:governance": "pnpm test:run && pnpm check:design-system",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true }); rmSync('.tsbuild', { recursive: true, force: true })\"",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o storybook-static",
    "test:storybook": "vitest --config vitest.storybook.config.ts",
    "test:storybook:run": "vitest run --config vitest.storybook.config.ts"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "dependencies": {
    "@afenda/design-system": "workspace:*",
    "@base-ui/react": "^1.6.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@afenda/typescript-config": "workspace:*",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "^4.11.0",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "vitest": "catalog:",
    "playwright": "^1.61.0",
    "@vitest/browser": "3.2.6",
    "@vitest/coverage-v8": "3.2.6"
  }
}
