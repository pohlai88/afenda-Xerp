{
  "name": "@afenda/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared UI primitives foundation",
  "type": "module",
  "imports": {
    "#/*": {
      "@afenda/ui/development": "./src/*",
      "default": "./dist/*"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./afenda-ui.css": {
      "types": "./dist/styles/afenda-ui.css",
      "import": "./dist/styles/afenda-ui.css",
      "default": "./dist/styles/afenda-ui.css"
    },
    "./governance": {
      "types": "./dist/governance/index.d.ts",
      "import": "./dist/governance/index.js",
      "default": "./dist/governance/index.js"
    },
    "./governance/*": {
      "types": "./dist/governance/*.d.ts",
      "import": "./dist/governance/*.js",
      "default": "./dist/governance/*.js"
    },
    "./lib/utils": {
      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/lib/utils.js",
      "default": "./dist/lib/utils.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.lib.json && node --input-type=module -e \"import { copyFileSync, mkdirSync } from 'node:fs'; mkdirSync('dist/styles', { recursive: true }); copyFileSync('src/styles/afenda-ui.css', 'dist/styles/afenda-ui.css');\"",
    "dev": "tsc -b tsconfig.lib.json --watch",
    "typecheck": "tsc -b tsconfig.lib.json --pretty false && tsc -p tsconfig.vitest.json --noEmit",
    "typecheck:stories": "tsc -p tsconfig.stories.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "test:interaction": "vitest run --config vitest.config.ts .interaction.test",
    "test:ui": "vitest --config vitest.config.ts --ui",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "check:design-system": "tsx scripts/check-design-system-consumption.ts",
    "test:governance:run": "vitest run --config vitest.config.ts src/__tests__/governance",
    "check:governance": "pnpm test:governance:run && pnpm check:design-system",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true }); rmSync('.tsbuild', { recursive: true, force: true })\""
  },
  "sideEffects": [
    "./dist/styles/afenda-ui.css"
  ],
  "dependencies": {
    "@afenda/design-system": "workspace:*",
    "@base-ui/react": "^1.6.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.525.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react-day-picker": "^10.0.1",
    "react-resizable-panels": "^4.11.2",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@afenda/testing": "workspace:*",
    "@afenda/typescript-config": "workspace:*",
    "@storybook/react": "^10.4.6",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "3.2.6",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "^4.11.0",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "vitest": "catalog:"
  }
}
