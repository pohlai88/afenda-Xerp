{
  "name": "@afenda/database",
  "version": "0.0.0",
  "private": true,
  "description": "Database schema and Drizzle foundation (TIP-003)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "import": "./dist/env.js",
      "default": "./dist/env.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js",
      "default": "./dist/schema/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "pnpm run build",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "biome check src",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "format": "biome check --write src",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\"",
    "pretest": "pnpm db:validate-journal",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx scripts/repair-drizzle-journal.ts && drizzle-kit migrate --config drizzle.config.ts",
    "db:validate-journal": "tsx scripts/validate-journal.ts",
    "db:repair-journal": "tsx scripts/repair-drizzle-journal.ts",
    "db:repair-journal:check": "tsx scripts/repair-drizzle-journal.ts --check",
    "db:compare-migrations": "tsx scripts/compare-migrations.ts",
    "db:migration-hashes": "tsx scripts/list-migration-hashes.ts",
    "db:migration-status": "tsx scripts/db-migration-status.ts",
    "db:url-hints": "tsx scripts/db-url-hints.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:seed:platform": "tsx scripts/seed-platform.ts",
    "db:seed:dev": "tsx scripts/seed-dev.ts",
    "db:seed:test": "tsx scripts/seed-test.ts",
    "db:bootstrap:local": "tsx scripts/bootstrap-local.ts",
    "db:bootstrap:preview": "tsx scripts/bootstrap-preview.ts",
    "db:verify:seed": "tsx scripts/verify-seed.ts"
  },
  "sideEffects": false,
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.3"
  }
}
