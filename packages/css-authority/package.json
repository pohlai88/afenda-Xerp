{
  "name": "@afenda/css-authority",
  "version": "0.0.0",
  "private": true,
  "description": "CSS Authority Registry — vendored shadcn theme, extensions, generated CSS-TOKEN-* registry (PAS-005)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./css/afenda-css-authority.css": {
      "import": "./dist/css/afenda-css-authority.css",
      "default": "./dist/css/afenda-css-authority.css"
    },
    "./generated/css-authority-registry.json": {
      "import": "./dist/generated/css-authority-registry.json",
      "default": "./dist/generated/css-authority-registry.json"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsx scripts/generate-css-authority-registry.ts && tsc -b",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false && tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "check:governance": "tsx ../../scripts/governance/check-css-authority-conformance.mts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true })\"",
    "generate:css-authority-registry": "tsx scripts/generate-css-authority-registry.ts"
  },
  "sideEffects": [
    "./dist/css/afenda-css-authority.css"
  ],
  "dependencies": {},
  "devDependencies": {
    "@afenda/typescript-config": "workspace:*",
    "tsx": "^4.20.3",
    "vitest": "catalog:"
  }
}
