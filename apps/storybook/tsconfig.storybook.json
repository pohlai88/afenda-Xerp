{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@afenda/typescript-config/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "5.0",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "exactOptionalPropertyTypes": false,
    "paths": {
      "@afenda/shadcn-studio-v2/shadcn-default.css": [
        "../../packages/shadcn-studio-v2/src/styles/shadcn-default.css"
      ],
      "@afenda/shadcn-studio-v2/lab": [
        "../../packages/shadcn-studio-v2/src/storybook/lab.ts"
      ],
      "@afenda/shadcn-studio-v2": [
        "../../packages/shadcn-studio-v2/src/index.ts"
      ],
      "@/components/ui/*": [
        "../../packages/shadcn-studio-v2/src/components/ui/*"
      ],
      "@/lib/utils": ["../../packages/shadcn-studio-v2/src/lib/cn.ts"],
      "@/*": ["../../packages/shadcn-studio-v2/src/*"],
      "@storybook/react": ["./node_modules/@storybook/react"],
      "storybook/test": ["./node_modules/storybook/dist/test/index.d.ts"],
      "next/link": ["../../packages/testing/src/mocks/next-link.tsx"],
      "next/image": ["../../packages/testing/src/mocks/next-image.tsx"],
      "next/dynamic": ["../../packages/testing/src/mocks/next-dynamic.tsx"],
      "next/navigation": [
        "../../packages/testing/src/mocks/next-navigation.tsx"
      ]
    }
  },
  "include": [
    ".storybook/*.ts",
    ".storybook/*.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "./stories/**/*.ts",
    "./stories/**/*.tsx",
    "vitest.storybook.config.ts",
    "vitest.storybook-a11y.config.ts",
    "../../packages/testing/src/mocks/*.tsx",
    "../../packages/testing/src/mocks/*.ts",
    "../../packages/shadcn-studio-v2/src/**/*.ts",
    "../../packages/shadcn-studio-v2/src/**/*.tsx"
  ],
  "exclude": [
    "../../packages/shadcn-studio-v2/src/**/__tests__/**",
    "../../packages/shadcn-studio-v2/src/**/*.test.ts",
    "../../packages/shadcn-studio-v2/src/**/*.test.tsx"
  ]
}
