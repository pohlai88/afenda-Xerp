{
  "name": "@afenda/erp",
  "version": "0.0.0",
  "private": true,
  "description": "Afenda ERP application entry point (ADR-0027 presentation reset skeleton)",
  "scripts": {
    "build": "next build",
    "predev": "pnpm --filter @afenda/kernel build && pnpm --filter @afenda/database build && pnpm --filter @afenda/permissions build && pnpm --filter @afenda/auth build && pnpm --filter @afenda/execution build",
    "dev": "next dev --port 3000 --webpack",
    "dev:turbopack": "next dev --port 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "test:e2e:smoke": "playwright test --project=chromium-smoke --pass-with-no-tests",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; for (const d of ['.next', 'out']) rmSync(d, { recursive: true, force: true })\""
  },
  "dependencies": {
    "@afenda/auth": "workspace:*",
    "@afenda/database": "workspace:*",
    "@afenda/enterprise-knowledge": "workspace:*",
    "@afenda/execution": "workspace:*",
    "@afenda/erp-modules": "workspace:*",
    "@afenda/kernel": "workspace:*",
    "@afenda/observability": "workspace:*",
    "@afenda/permissions": "workspace:*",
    "@afenda/shadcn-studio": "workspace:*",
    "better-auth": "^1.6.19",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@afenda/testing": "workspace:*",
    "@afenda/typescript-config": "workspace:*",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "shadcn": "^4.11.0",
    "tailwindcss": "catalog:",
    "vitest": "catalog:",
    "zod-openapi": "^6.0.0"
  }
}
