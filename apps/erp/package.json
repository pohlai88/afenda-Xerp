{
  "name": "@afenda/erp",
  "version": "0.0.0",
  "private": true,
  "description": "Afenda ERP application shell entry point",
  "scripts": {
    "build": "next build",
    "predev": "pnpm --filter @afenda/kernel build && pnpm --filter @afenda/database build && pnpm --filter @afenda/permissions build",
    "dev": "next dev --port 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; for (const d of ['.next', 'out']) rmSync(d, { recursive: true, force: true })\""
  },
  "dependencies": {
    "@afenda/appshell": "workspace:*",
    "@afenda/auth": "workspace:*",
    "@afenda/database": "workspace:*",
    "@afenda/design-system": "workspace:*",
    "@afenda/entitlements": "workspace:*",
    "@afenda/execution": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "drizzle-orm": "^0.45.2",
    "@afenda/kernel": "workspace:*",
    "@afenda/metadata": "workspace:*",
    "@afenda/metadata-ui": "workspace:*",
    "@afenda/observability": "workspace:*",
    "@afenda/permissions": "workspace:*",
    "@afenda/ui": "workspace:*",
    "@supabase/server": "^1.1.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "better-auth": "^1.6.19",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@afenda/testing": "workspace:*",
    "@afenda/typescript-config": "workspace:*",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/postcss": "catalog:",
    "dotenv": "^17.4.2",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "shadcn": "^4.11.0",
    "tailwindcss": "catalog:",
    "vitest": "catalog:"
  }
}
