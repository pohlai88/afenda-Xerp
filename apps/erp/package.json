{
  "name": "@afenda/erp",
  "version": "0.0.0",
  "private": true,
  "description": "Afenda ERP application shell entry point",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; for (const d of ['.next', 'out']) rmSync(d, { recursive: true, force: true })\""
  },
  "dependencies": {
    "@afenda/appshell": "workspace:*",
    "@afenda/auth": "workspace:^",
    "@afenda/database": "workspace:^",
    "@afenda/design-system": "workspace:*",
    "@afenda/observability": "workspace:^",
    "@supabase/server": "^1.1.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "better-auth": "^1.6.19",
    "next": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@afenda/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "vitest": "catalog:"
  }
}
