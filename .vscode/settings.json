{
  "biome.configurationPath": "${workspaceFolder}/biome.lsp.jsonc",
  "biome.enabled": true,
  "biome.lsp.bin": {
    "darwin-arm64": "${workspaceFolder}/node_modules/@biomejs/cli-darwin-arm64/biome",
    "darwin-x64": "${workspaceFolder}/node_modules/@biomejs/cli-darwin-x64/biome",
    "linux-arm64": "${workspaceFolder}/node_modules/@biomejs/cli-linux-arm64/biome",
    "linux-x64": "${workspaceFolder}/node_modules/@biomejs/cli-linux-x64/biome",
    "win32-arm64": "${workspaceFolder}/node_modules/@biomejs/cli-win32-arm64/biome.exe",
    "win32-x64": "${workspaceFolder}/node_modules/@biomejs/cli-win32-x64/biome.exe"
  },
  "biome.lsp.trace.server": "off",
  "biome.lsp.watcher.kind": "none",
  "biome.requireConfiguration": true,
  "biome.runFromTemporaryLocation": false,
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnPaste": false,
  "editor.formatOnSave": true,
  "emmet.showExpandedAbbreviation": "never",
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,
  "typescript.tsserver.useSyntaxServer": "always",
  "vitest.enable": false,
  "vitest.disabledWorkspaceFolders": ["."],
  "typescript.tsserver.watchOptions": {
    "excludeDirectories": [
      "**/node_modules",
      "**/.git",
      "**/dist",
      "**/.tsbuild",
      "**/_reference",
      "**/docs",
      "**/.cursor",
      "**/packages/ai-governance",
      "**/packages/architecture-authority"
    ]
  },
  "typescript.preferences.includePackageJsonAutoImports": "auto",
  "[css]": {
    "biome.enabled": false,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "never",
      "source.organizeImports.biome": "never"
    }
  },
  "[graphql]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[html]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "biome.enabled": true,
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "biome.enabled": true,
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "biome.enabled": false,
    "editor.defaultFormatter": "vscode.json-language-features",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "never",
      "source.organizeImports.biome": "never"
    }
  },
  "files.associations": {
    "*.mdc": "markdown"
  },
  "[markdown]": {
    "biome.enabled": false,
    "editor.defaultFormatter": "yzhang.markdown-all-in-one",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "never",
      "source.organizeImports.biome": "never"
    }
  },
  "[mdx]": {
    "biome.enabled": false,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.codeActionsOnSave": {
      "source.fixAll.biome": "never",
      "source.organizeImports.biome": "never"
    }
  },
  "[svelte]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "biome.enabled": true,
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "biome.enabled": true,
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[vue]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[yaml]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "css.validate": false,
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit",
    "source.organizeImports.biome": "explicit"
  },
  "prettier.requireConfig": true,
  "prettier.configPath": "./prettier.config.mjs",
  "prettier.documentSelectors": ["**/*.mdx", "**/*.css"],
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/_reference/**": true,
    "**/coverage/**": true,
    "**/dist/**": true,
    "**/node_modules/**": true,
    "**/out/**": true,
    "**/docs/**": true,
    "**/.cursor/**": true,
    "**/packages/ai-governance/**": true,
    "**/packages/architecture-authority/**": true,
    "**/storybook-static/**": true
  },
  "search.exclude": {
    "**/_reference": true,
    "**/.cursor": true
  },
  "shadcnstudio.telemetry.enabled": false
}
