{
  "name": "afenda",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "build:governance-dist": "pnpm --filter @afenda/kernel exec tsc -b --force && pnpm --filter @afenda/database exec tsc -b --force && pnpm --filter @afenda/permissions exec tsc -b --force && pnpm --filter @afenda/appshell exec tsc -b --force && pnpm --filter @afenda/observability exec tsc -b --force && pnpm --filter @afenda/architecture-authority exec tsc -b --force",
    "dev": "turbo run dev",
    "lint": "ultracite check",
    "typecheck": "turbo run typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "test:run:storybook": "pnpm --filter @afenda/storybook test:storybook:run",
    "test:run:all": "vitest run && pnpm test:run:storybook",
    "test:run:affected": "turbo run test:run --affected",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:interaction": "pnpm --filter @afenda/testing test:interaction && pnpm --filter @afenda/ui test:interaction && pnpm --filter @afenda/appshell test:interaction",
    "test:ui": "vitest --ui",
    "format": "ultracite fix",
    "format:check": "biome ci .",
    "ci:biome": "biome ci .",
    "check": "pnpm ci:biome && pnpm typecheck && pnpm test:run:all",
    "ci": "pnpm ci:biome && pnpm typecheck && pnpm test:run:all && pnpm build && pnpm quality",
    "check:css-governance": "tsx scripts/css/check-css-governance.mts",
    "check:downstream-integration": "tsx scripts/governance/check-downstream-integration.mts",
    "check:csp-third-party": "tsx scripts/governance/check-csp-third-party.mts",
    "check:erp-observability": "tsx scripts/governance/check-erp-observability.mts",
    "check:kernel-context-surface": "tsx scripts/governance/check-kernel-context-surface.mts",
    "check:database-tenant-domain-surface": "tsx scripts/governance/check-database-tenant-domain-surface.mts",
    "check:erp-context-surface": "tsx scripts/governance/check-erp-context-surface.mts",
    "check:permissions-scope-grants-surface": "tsx scripts/governance/check-permissions-scope-grants-surface.mts",
    "check:appshell-context-surface": "tsx scripts/governance/check-appshell-context-surface.mts",
    "check:observability-surface": "tsx scripts/governance/check-observability-surface.mts",
    "check:architecture-authority-surface": "tsx scripts/governance/check-architecture-authority-surface.mts",
    "check:multi-tenancy-dependency-rules": "tsx scripts/governance/check-multi-tenancy-dependency-rules.mts",
    "check:multi-tenancy-dos-prohibitions": "tsx scripts/governance/check-multi-tenancy-dos-prohibitions.mts",
    "check:delivery-evidence-surface": "tsx scripts/governance/check-delivery-evidence-surface.mts",
    "check:api-contracts": "tsx scripts/api-contract/check-api-contracts.mts",
    "quality:css": "tsx scripts/css/check-css-governance.mts",
    "quality:csp-third-party": "tsx scripts/governance/check-csp-third-party.mts",
    "quality:erp-observability": "tsx scripts/governance/check-erp-observability.mts",
    "quality:kernel-context-surface": "tsx scripts/governance/check-kernel-context-surface.mts",
    "quality:database-tenant-domain-surface": "tsx scripts/governance/check-database-tenant-domain-surface.mts",
    "quality:erp-context-surface": "tsx scripts/governance/check-erp-context-surface.mts",
    "quality:permissions-scope-grants-surface": "tsx scripts/governance/check-permissions-scope-grants-surface.mts",
    "quality:appshell-context-surface": "tsx scripts/governance/check-appshell-context-surface.mts",
    "quality:observability-surface": "tsx scripts/governance/check-observability-surface.mts",
    "quality:architecture-authority-surface": "tsx scripts/governance/check-architecture-authority-surface.mts",
    "quality:multi-tenancy-dependency-rules": "tsx scripts/governance/check-multi-tenancy-dependency-rules.mts",
    "quality:multi-tenancy-dos-prohibitions": "tsx scripts/governance/check-multi-tenancy-dos-prohibitions.mts",
    "quality:delivery-evidence-surface": "tsx scripts/governance/check-delivery-evidence-surface.mts",
    "quality": "pnpm quality:boundaries && pnpm quality:exports && pnpm quality:migrations && pnpm quality:architecture && pnpm quality:architecture-drift && pnpm quality:ai-governance && pnpm quality:release-gate && pnpm quality:css && pnpm quality:csp-third-party && pnpm quality:erp-observability && pnpm build:governance-dist && pnpm quality:kernel-context-surface && pnpm quality:database-tenant-domain-surface && pnpm quality:erp-context-surface && pnpm quality:permissions-scope-grants-surface && pnpm quality:appshell-context-surface && pnpm quality:observability-surface && pnpm quality:architecture-authority-surface && pnpm quality:multi-tenancy-dependency-rules && pnpm quality:multi-tenancy-dos-prohibitions && pnpm quality:delivery-evidence-surface",
    "quality:boundaries": "node scripts/quality/check-package-boundaries.mjs",
    "quality:exports": "node scripts/quality/check-public-exports.mjs",
    "quality:migrations": "node scripts/quality/check-migrations.mjs",
    "quality:architecture": "node scripts/quality/check-architecture.mjs",
    "quality:architecture-drift": "node scripts/architecture/drift.mjs",
    "quality:preview-policy": "node scripts/quality/check-preview-policy.mjs",
    "quality:release-gate": "node scripts/quality/check-release-gates.mjs",
    "quality:ai-governance": "node scripts/quality/check-ai-governance.mjs",
    "architecture:report": "node scripts/architecture/report.mjs",
    "architecture:owners": "node scripts/architecture/owners.mjs",
    "architecture:dependencies": "node scripts/architecture/dependencies.mjs",
    "architecture:cycles": "node scripts/architecture/cycles.mjs",
    "architecture:drift": "node scripts/architecture/drift.mjs",
    "fix": "ultracite fix",
    "clean": "turbo run clean",
    "env:sync": "node scripts/sync-env.mjs",
    "env:doctor": "node scripts/env-doctor.mjs",
    "migrate": "pnpm --filter @afenda/database db:migrate",
    "migrate:deploy": "pnpm --filter @afenda/database db:migrate",
    "db:generate": "pnpm --filter @afenda/database db:generate",
    "db:seed:platform": "pnpm --filter @afenda/database db:seed:platform",
    "db:seed:dev": "pnpm --filter @afenda/database db:seed:dev",
    "db:seed:test": "pnpm --filter @afenda/database db:seed:test",
    "db:seed:demo": "pnpm --filter @afenda/database db:seed:demo",
    "db:bootstrap:local": "pnpm --filter @afenda/database db:bootstrap:local",
    "db:bootstrap:preview": "pnpm --filter @afenda/database db:bootstrap:preview",
    "db:verify:seed": "pnpm --filter @afenda/database db:verify:seed",
    "auth:bootstrap:dev": "pnpm --filter @afenda/auth auth:bootstrap:dev",
    "auth": "better-auth",
    "studio:toolbar": "pnpm studio:toolbar:app",
    "studio:toolbar:app": "npx shadcn-studio-extension-cli@latest -a 3000 -p 3200 -s",
    "studio:toolbar:docs": "npx shadcn-studio-extension-cli@latest -a 3001 -p 3200 -s",
    "storybook:ui": "pnpm --filter @afenda/storybook storybook",
    "storybook:build": "pnpm --filter @afenda/storybook storybook:build",
    "test:storybook:run": "pnpm --filter @afenda/storybook test:storybook:run",
    "ui:guard": "node scripts/governance/ui-guard.mjs",
    "ui:guard:scan": "node scripts/governance/ui-guard.mjs --scan-only --fix-hint",
    "ui:guard:hints": "node scripts/governance/ui-guard.mjs --fix-hint"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@biomejs/biome": "2.4.16",
    "@testing-library/jest-dom": "catalog:",
    "@types/node": "^22.15.30",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "jsdom": "catalog:",
    "turbo": "^2.5.4",
    "typescript": "catalog:",
    "ultracite": "7.8.3",
    "vitest": "catalog:"
  }
}
