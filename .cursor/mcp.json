{
  "mcpServers": {
    "filesystem": {
      "command": "node",
      "args": [
        "${workspaceFolder}/.cursor/mcp/filesystem.mjs"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "-y",
        "shadcn@latest",
        "mcp",
        "-c",
        "packages/shadcn-studio"
      ]
    },
    "shadcn-studio": {
      "command": "node",
      "args": [
        "${workspaceFolder}/.cursor/mcp/shadcn-studio.mjs"
      ],
      "envFile": "${workspaceFolder}/.env"
    },
    "storybook": {
      "command": "node",
      "args": [
        "${workspaceFolder}/.cursor/mcp/storybook.mjs"
      ]
    },
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "env": {
        "PYTHONIOENCODING": "utf-8"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--config",
        "apps/developer/playwright.config.mts"
      ]
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=esxjzvcfqtaxmiwjntje&features=docs%2Caccount%2Cdatabase%2Cdebugging%2Cdevelopment%2Cfunctions%2Cbranching%2Cstorage"
    },
    "better-auth": {
      "type": "http",
      "url": "https://mcp.better-auth.com/mcp"
    },
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    },
    "figma-desktop": {
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "resend-dev": {
      "command": "node",
      "args": [
        "${workspaceFolder}/.cursor/mcp/resend-dev.mjs"
      ]
    },
    "resend-docs": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://resend.com/docs/mcp"
      ]
    }
  }
}
