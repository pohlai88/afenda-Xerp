{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "prompt",
        "prompt": "Repo: afenda-Xerp (pnpm + turbo). Apps: apps/erp (3000), apps/docs (3001). Governance: AGENTS.md + .cursor/rules/. Skills: .cursor/skills/. Use pnpm only. Hooks guard shell/MCP policy and run scoped stop quality gates. Prefer typecheck, pnpm check, and tests over starting dev servers."
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/guard-pre-tool-use.mjs",
        "matcher": "Write|StrReplace|Delete|EditNotebook|ApplyPatch",
        "timeout": 5
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/guard-shell-policy.mjs",
        "timeout": 5
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "node .cursor/hooks/guard-mcp-policy.mjs",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/stop-quality-gates.mjs",
        "timeout": 180,
        "loop_limit": 3
      }
    ]
  }
}
