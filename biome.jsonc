{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite/biome/core",
    "ultracite/biome/react",
    "ultracite/biome/next",
    "ultracite/biome/vitest",
    "ultracite/biome/type-aware"
  ],
  "files": {
    "includes": [
      "!!**/.cursor",
      "!!**/packages/ui/src/components/shadcn-studio",
      "!!**/temp-docx",
      "!!**/*.docx",
      "!!**/Modern_Afenda_ERP_Master_Plan_Final_Clean.docx",
      "!!**/*.tsbuildinfo",
      "!**/packages/database/src/migrations/meta",
      "!!**/dist",
      "!!**/.next",
      "!!**/.turbo",
      "!!**/packages/ai-governance",
      "!!**/pnpm-lock.yaml",
      "!!**/packages/*/scripts/**/*.js"
    ]
  },
  "formatter": {
    "useEditorconfig": true
  },
  "linter": {
    "rules": {
      "correctness": {
        "useImportExtensions": "off",
        "noUnresolvedImports": "off"
      },
      "complexity": {
        "useLiteralKeys": "off"
      },
      "suspicious": {
        "noDeprecatedImports": "warn"
      }
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true,
    "defaultBranch": "main"
  },
  "overrides": [
    {
      "includes": [
        "packages/database/src/index.ts",
        "packages/database/src/schema/index.ts",
        "packages/*/src/index.ts",
        "packages/design-system/src/validation/index.ts",
        "packages/design-system/src/recipes/registry.ts",
        "packages/design-system/src/tokens/registry.ts",
        "packages/design-system/src/variants/registry.ts",
        "packages/design-system/src/css/token-css-variable.ts",
        "packages/design-system/src/policies/**/*.ts"
      ],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/ui/**", "packages/appshell/**"],
      "linter": {
        "rules": {
          "performance": {
            "noNamespaceImport": "off",
            "noBarrelFile": "off",
            "noImgElement": "off",
            "useTopLevelRegex": "off"
          },
          "style": {
            "noNestedTernary": "off",
            "noExportedImports": "off",
            "useDefaultSwitchClause": "off"
          },
          "correctness": {
            "noNestedComponentDefinitions": "off",
            "useImageSize": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noVoid": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off",
            "noDocumentCookie": "off",
            "useAwait": "off",
            "noMisplacedAssertion": "off",
            "noEmptyBlockStatements": "off"
          },
          "a11y": {
            "useValidAnchor": "off",
            "noLabelWithoutControl": "off",
            "useAriaPropsSupportedByRole": "off",
            "noStaticElementInteractions": "off",
            "noNoninteractiveElementInteractions": "off",
            "useKeyWithClickEvents": "off",
            "noSvgWithoutTitle": "off"
          },
          "security": {
            "noDangerouslySetInnerHtml": "off"
          }
        }
      }
    },
    {
      "includes": ["scripts/governance/**"],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          },
          "correctness": {
            "noUnusedFunctionParameters": "off"
          },
          "performance": {
            "useTopLevelRegex": "off"
          },
          "style": {
            "useBlockStatements": "off"
          },
          "suspicious": {
            "noAssignInExpressions": "off",
            "noBitwiseOperators": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.stories.tsx", "**/_storybook/**/*.tsx"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off"
          }
        }
      },
      "assist": {
        "actions": {
          "source": {
            "organizeImports": "off"
          }
        }
      }
    }
  ]
}
