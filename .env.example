# Afenda monorepo environment variables
#
# Human-managed sources (never edit generated .env outputs directly):
#   .env.config  — shared non-secret configuration
#   .env.secret  — secrets and credentials
#
# Sync workflow:
#   pnpm env:console              # interactive env console (recommended)
#   pnpm env:console refresh      # sync + doctor + migration URL probe
#   pnpm env:sync                 # low-level: write repo env targets only
#   pnpm env:doctor               # low-level: validate sources and targets
#
# Optional overlays:
#   .env.config.local        merged for local dev (default)
#   .env.config.production   committed production policy overlay
#
# Production tenant routing (see .env.config.production):
#   NEXT_PUBLIC_BASE_DOMAIN=nexuscanon.com  → {tenantSlug}.nexuscanon.com
#   Path fallback: /t/{tenantSlug}/… on NEXT_PUBLIC_SITE_URL
#
# Generated targets:
#   .env
#   .env.local
#   apps/erp/.env.local
#   apps/docs/.env.local
#   packages/database/.env
#   packages/execution/.env
#
# Push to Vercel (requires `vercel link` + VERCEL_TOKEN in .env.secret):
#   pnpm env:sync -- --overlay production --vercel production

# --- .env.config (non-secret) ---

# Supabase browser-safe
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_[your-key]
SUPABASE_JWT_KID=[jwks-kid-from-dashboard]
SUPABASE_DB_REGION=ap-southeast-2
SUPABASE_DB_POOLER_HOST=aws-1-ap-southeast-2.pooler.supabase.com

# Derived automatically by `pnpm env:sync` (do not add to source files):
# SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY, SUPABASE_JWKS_URL, SUPABASE_PROJECT_REF
#
# Used by `@supabase/server` (API routes / Edge Functions): SUPABASE_URL,
# SUPABASE_PUBLISHABLE_KEY, SUPABASE_SECRET_KEY, SUPABASE_JWKS_URL

# Sentry public DSN
NEXT_PUBLIC_SENTRY_DSN=https://[key]@[org].ingest.[region].sentry.io/[project]

# Stripe price IDs (use STRIPE_PRICE_PRO, not legacy STRIPE_PRICE_ID)
STRIPE_DEFAULT_PLAN_KEY=pro
STRIPE_PRICE_PRO=price_[your-pro-price-id]

# Object storage (prefer OBJECT_STORAGE_* over legacy CLOUDFLARE_R2_*)
OBJECT_STORAGE_PROVIDER=r2
OBJECT_STORAGE_BUCKET=[bucket-name]
OBJECT_STORAGE_ENDPOINT=https://[account-id].r2.cloudflarestorage.com

# Better Auth Infrastructure KV identify endpoint (project-scoped; from dashboard)
BETTER_AUTH_IDENTIFY_URL=https://kv.better-auth.com/projects/[your-project-id]
# Derived at sync: BETTER_AUTH_KV_URL, NEXT_PUBLIC_BETTER_AUTH_KV_URL

# Better Auth application instance (ERP origin)
BETTER_AUTH_URL=http://localhost:3000

# Platform OAuth client IDs (public; pair with secrets in .env.secret)
AFENDA_OAUTH_GOOGLE_CLIENT_ID=
AFENDA_OAUTH_GITHUB_CLIENT_ID=

# Transactional auth email (Resend) — from-address may live in .env.config or .env.secret
# AFENDA_AUTH_EMAIL_FROM=Afenda ERP <auth@yourdomain.com>

# CSP strategy: hybrid (public SRI + protected nonce), nonce, or sri
ERP_CSP_STRATEGY=hybrid

# Redis (Upstash REST — URL in config, token in secret)
UPSTASH_REDIS_REST_URL=https://[your-upstash-endpoint].upstash.io

# Trigger.dev (@afenda/execution — project ref + API URL in config; secret in .env.secret)
TRIGGER_PROJECT_REF=proj_[your-project-ref]
TRIGGER_API_URL=https://api.trigger.dev

# Execution spine policy (enqueue vs scheduled drain)
# Local default: OUTBOX_SCHEDULER_REQUIRED=false (degraded — no remote cron registration)
# Local spine profile: OUTBOX_SCHEDULER_REQUIRED=true + TRIGGER_SECRET_KEY=tr_dev_*
# Production overlay (.env.config.production): OUTBOX_SCHEDULER_REQUIRED=true
OUTBOX_SCHEDULER_REQUIRED=false
WORKER_RELEASE_CHECK_REQUIRED=false
ALLOW_DEGRADED_EXECUTION=false

# Governed internal v1 REST rate limiting — `memory` for local dev; omit in production for Postgres buckets
API_RATE_LIMIT_PROVIDER=memory

# Release alignment (optional explicit override; Vercel sets VERCEL_GIT_COMMIT_SHA automatically)
# AFENDA_RELEASE_SHA=[git-commit-sha]

# @afenda/docs — optional GitHub Enterprise API root (default: https://api.github.com)
# DOCS_GITHUB_API_BASE_URL=https://api.octocorp.ghe.com

# --- .env.secret ---

# Better Auth signing secret (min 32 chars — generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=[your-32-char-or-longer-secret]

# Machine S2S internal v1 REST (ADR-0035/0036 — apps/erp only; pair with service-token-required routes)
# Required when deploying GET /api/internal/v1/auth/service-actor/ping or any service-token route.
# Issuers (workers, probes) and ERP must share this secret. Not used for human OAuth/session auth.
AFENDA_INTERNAL_S2S_SIGNING_SECRET=[your-32-char-or-longer-s2s-signing-secret]

# Platform OAuth client secrets (pair with AFENDA_OAUTH_*_CLIENT_ID in .env.config)
AFENDA_OAUTH_GOOGLE_CLIENT_SECRET=
AFENDA_OAUTH_GITHUB_CLIENT_SECRET=

# Local dev sign-in (after pnpm db:bootstrap:local → pnpm auth:bootstrap:dev)
# Email defaults to dev-admin@localhost.afenda; override with AFENDA_DEV_LOGIN_EMAIL
AFENDA_DEV_LOGIN_PASSWORD=[your-local-dev-password-min-8-chars]
# Optional override for E2E workspace_reader (defaults to ${AFENDA_DEV_LOGIN_PASSWORD}-viewer after auth:bootstrap:dev)
AFENDA_E2E_VIEWER_LOGIN_PASSWORD=

# System Admin diagnostics — set to 1 to run full delegated Phase 9 gates on every page load (slow).
# Default page load uses structure-only; prefer the in-app "Run full delegated gate check" action instead.
# AFENDA_ACCOUNTING_READINESS_DIAGNOSTICS_FULL=1

# Better Auth Infrastructure (dashboard / dash / sentinel plugins)
BETTER_AUTH_API_KEY=ba_[your-api-key]

# Resend transactional email (auth verification, password reset, member invitations, 2FA OTP)
AFENDA_AUTH_EMAIL_API_KEY=re_[your-resend-api-key]
# AFENDA_AUTH_EMAIL_FROM=Afenda ERP <auth@yourdomain.com>
# Passwordless 2FA scope — credential-only (default) | enforce-all (requires future Better Auth hooks; no-op today)
# AFENDA_AUTH_PASSWORDLESS_TWO_FACTOR=credential-only
AFENDA_RESEND_WEBHOOK_SECRET=whsec_[your-resend-webhook-secret]

# Resend developer MCP only (Cursor resend-dev server — NOT ERP runtime / tenant mail)
# RESEND_API_KEY=re_[your-resend-dev-or-sandbox-api-key]
# RESEND_FROM=onboarding@resend.dev

# Supabase Postgres (Afenda builds connection URLs from password + region + project ref)
SUPABASE_DB_PASSWORD=[YOUR-DATABASE-PASSWORD]
SUPABASE_SECRET_KEY=sb_secret_[your-key]
UPSTASH_REDIS_REST_TOKEN=[your-upstash-token]

# Optional explicit Postgres overrides (otherwise built at runtime):
# DATABASE_URL                 — explicit app override
# DATABASE_URL_DEDICATED       — dedicated pooler (db.[ref].supabase.co:6543)
# DATABASE_URL_DIRECT          — migrations; prefer session pooler when direct host fails locally:
#   postgresql://postgres.[ref]:[password]@[SUPABASE_DB_POOLER_HOST]:5432/postgres
# DATABASE_URL_TRANSACTION       — shared transaction pooler (port 6543, app default)
# DATABASE_URL_SESSION           — shared session pooler (port 5432)

OBJECT_STORAGE_ACCESS_KEY_ID=[r2-access-key]
OBJECT_STORAGE_SECRET_ACCESS_KEY=[r2-secret-key]

STRIPE_SECRET_KEY=sk_test_[your-key]
STRIPE_WEBHOOK_SECRET=whsec_[your-secret]

# Turborepo remote cache (secret only — do not duplicate TURBO_TEAM in .env.config)
TURBO_TEAM=[vercel-team-slug]
TURBO_TOKEN=[turbo-token]

# shadcn/studio MCP — license from https://shadcnstudio.com/mcp/onboarding
# Synced to .env for .cursor/mcp.json → shadcn-studio
SHADCN_STUDIO_LICENSE_KEY=[your-shadcn-studio-license-key]
SHADCN_STUDIO_ACCOUNT_EMAIL=[your-shadcn-studio-account-email]
# shadcncraft Pro React / Pro Figma + React (agent skills + @shadcncraft registry blocks)
SHADCNCRAFT_LICENSE_KEY=[your-shadcncraft-license-key]
SHADCNCRAFT_INSTANCE_NAME=[your-shadcncraft-instance-name]

# Figma — auth shell design file (optional; used in Figma MCP / /ftc prompts)
# FIGMA_AUTH_DESIGN_URL=https://www.figma.com/design/2ZNqNOxyNb5TwCTBIaMVPD/loginauth

# Trigger.dev DEV secret key (cloud.trigger.dev → API Keys; use tr_prod_* in production)
TRIGGER_SECRET_KEY=tr_dev_[your-dev-secret-key]
# Production-only Trigger key — merged over TRIGGER_SECRET_KEY when pushing Vercel production overlay
TRIGGER_SECRET_KEY_PROD=tr_prod_[your-prod-secret-key]

# @afenda/docs — GitHub REST token for last-modified page footer during production builds
# Fine-grained or classic token with contents:read on afenda-Xerp; optional (raises API rate limits)
DOCS_GITHUB_TOKEN=ghp_[your-github-token-with-contents-read]

# @afenda/docs — GitHub App for feedback → Discussions (optional)
# DOCS_GITHUB_APP_ID=1234567
# DOCS_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
