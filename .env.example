# Afenda monorepo environment variables
#
# Human-managed sources (never edit generated .env outputs directly):
#   .env.config  — shared non-secret configuration
#   .env.secret  — secrets and credentials
#
# Sync workflow:
#   pnpm env:sync          # write repo env targets from config + secret
#   pnpm env:doctor        # validate sources and sync freshness
#   pnpm env:sync -- --check
#
# Optional overlays:
#   .env.config.local        merged for local dev (default)
#   .env.config.production   merged with --overlay production
#
# Generated targets:
#   .env
#   .env.local
#   apps/erp/.env.local
#   apps/docs/.env.local
#   packages/database/.env
#
# Push to Vercel (requires `vercel link` + VERCEL_TOKEN in .env.secret):
#   pnpm env:sync -- --overlay production --vercel production

# --- .env.config (non-secret) ---

# Supabase browser-safe
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_[your-key]
SUPABASE_JWT_KID=[jwks-kid-from-dashboard]
SUPABASE_DB_REGION=ap-southeast-2
SUPABASE_DB_POOLER_HOST=aws-1-ap-southeast-2.pooler.supabase.com

# Derived automatically by `pnpm env:sync` (do not add to source files):
# SUPABASE_URL, SUPABASE_PUBLISHABLE_KEY, SUPABASE_JWKS_URL, SUPABASE_PROJECT_REF
#
# Used by `@supabase/server` (API routes / Edge Functions): SUPABASE_URL,
# SUPABASE_PUBLISHABLE_KEY, SUPABASE_SECRET_KEY, SUPABASE_JWKS_URL

# Sentry public DSN
NEXT_PUBLIC_SENTRY_DSN=https://[key]@[org].ingest.[region].sentry.io/[project]

# Stripe price IDs (use STRIPE_PRICE_PRO, not legacy STRIPE_PRICE_ID)
STRIPE_DEFAULT_PLAN_KEY=pro
STRIPE_PRICE_PRO=price_[your-pro-price-id]

# Object storage (prefer OBJECT_STORAGE_* over legacy CLOUDFLARE_R2_*)
OBJECT_STORAGE_PROVIDER=r2
OBJECT_STORAGE_BUCKET=[bucket-name]
OBJECT_STORAGE_ENDPOINT=https://[account-id].r2.cloudflarestorage.com

# Better Auth Infrastructure KV identify endpoint (project-scoped; from dashboard)
BETTER_AUTH_IDENTIFY_URL=https://kv.better-auth.com/projects/[your-project-id]
# Derived at sync: BETTER_AUTH_KV_URL, NEXT_PUBLIC_BETTER_AUTH_KV_URL

# Better Auth application instance (ERP origin)
BETTER_AUTH_URL=http://localhost:3000

# --- .env.secret ---

# Better Auth signing secret (min 32 chars — generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=[your-32-char-or-longer-secret]

# Better Auth Infrastructure (dashboard / dash / sentinel plugins)
BETTER_AUTH_API_KEY=ba_[your-api-key]

# Supabase Postgres (Afenda builds connection URLs from password + region + project ref)
SUPABASE_DB_PASSWORD=[YOUR-DATABASE-PASSWORD]
SUPABASE_SECRET_KEY=sb_secret_[your-key]

# Optional explicit Postgres overrides (otherwise built at runtime):
# DATABASE_URL                 — explicit app override
# DATABASE_URL_DEDICATED       — dedicated pooler (db.[ref].supabase.co:6543)
# DATABASE_URL_DIRECT            — direct Postgres (db.[ref].supabase.co:5432)
# DATABASE_URL_TRANSACTION       — shared transaction pooler (port 6543, app default)
# DATABASE_URL_SESSION           — shared session pooler (port 5432)

OBJECT_STORAGE_ACCESS_KEY_ID=[r2-access-key]
OBJECT_STORAGE_SECRET_ACCESS_KEY=[r2-secret-key]

STRIPE_SECRET_KEY=sk_test_[your-key]
STRIPE_WEBHOOK_SECRET=whsec_[your-secret]

# Turborepo remote cache (secret only — do not duplicate TURBO_TEAM in .env.config)
TURBO_TEAM=[vercel-team-slug]
TURBO_TOKEN=[turbo-token]
