{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "biome.jsonc",
    "tsconfig.base.json",
    "tsconfig.library.json",
    "tsconfig.next.json",
    "tsconfig.vitest.base.json",
    "vitest.config.ts",
    "vitest.shared.ts"
  ],
  "tasks": {
    "//#lint": {
      "cache": false
    },
    "//#fix": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "quality": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
