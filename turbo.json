{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "tsconfig.json",
    "packages/typescript-config/*.json",
    "biome.jsonc",
    "pnpm-lock.yaml",
    "vitest.config.ts",
    "vitest.shared.ts"
  ],
  "globalPassThroughEnv": [
    "CI",
    "GITHUB_ACTIONS",
    "GITHUB_EVENT_NAME",
    "GITHUB_REF",
    "GITHUB_SHA",
    "TURBO_TEAM",
    "TURBO_TOKEN"
  ],
  "remoteCache": {
    "enabled": true
  },
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": ["node_modules/.cache/tsbuildinfo/**", "**/.tsbuildinfo"]
    },
    "lint": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test:run": {
      "dependsOn": ["^build"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.shared.ts"
      ],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "quality": {
      "cache": false
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "storybook:build": {
      "outputs": ["storybook-static/**"]
    },
    "test:storybook": {
      "cache": false
    },
    "test:storybook:run": {
      "cache": false,
      "outputs": ["coverage/**"]
    },
    "check:governance": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
