{
  "$schema": "https://turbo.build/schema.json",
  "futureFlags": {
    "globalConfiguration": true
  },
  "global": {
    "ui": "tui",
    "inputs": [
      "tsconfig.json",
      "packages/typescript-config/*.json",
      "biome.jsonc",
      "pnpm-lock.yaml",
      "vitest.config.ts",
      "vitest.shared.ts"
    ],
    "passThroughEnv": [
      "CI",
      "GITHUB_ACTIONS",
      "GITHUB_EVENT_NAME",
      "GITHUB_REF",
      "GITHUB_SHA",
      "TURBO_TEAM",
      "TURBO_TOKEN"
    ],
    "remoteCache": {
      "enabled": true
    }
  },
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "typecheck": {
      "dependsOn": ["topo"],
      "inputs": ["$TURBO_DEFAULT$", "**/*.{ts,tsx}"],
      "outputs": ["node_modules/.cache/tsbuildinfo/**", "**/.tsbuildinfo"]
    },
    "lint": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["transit"],
      "cache": false,
      "persistent": true
    },
    "test:run": {
      "dependsOn": ["transit"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.shared.ts"
      ],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "quality": {
      "cache": false
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "storybook:generate": {
      "cache": false,
      "outputs": ["apps/docs/src/app/docs-editorial-blocks.css"]
    },
    "storybook:build": {
      "outputs": ["storybook-static/**"]
    },
    "test:storybook": {
      "cache": false
    },
    "test:storybook:run": {
      "cache": false,
      "outputs": ["coverage/**"]
    },
    "test:e2e": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["blob-report/**", "e2e/test-results/**"]
    },
    "test:e2e:smoke": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["blob-report/**", "e2e/test-results/**"]
    },
    "check:governance": {
      "dependsOn": ["^build"],
      "outputs": []
    }
  }
}
