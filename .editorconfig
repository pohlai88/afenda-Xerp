# https://editorconfig.org — aligns editors with Biome + Prettier (CSS/MDX) + CI.
# Install "EditorConfig for VS Code" (recommended in .vscode/extensions.json).

root = true

[_reference/**]
root = false

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.mdc]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{yml,yaml}]
indent_size = 2
